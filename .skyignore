# Native extension: exclude Rust/native build inputs and npm page sources.
.git
.gitignore
.skyignore
.DS_Store
Thumbs.db
*.tmp
*.log

Cargo.toml
Cargo.lock
build.rs
build-native.ps1
src/
target/
native/src/
native/target/
native/dist/

# Keep the built extension page only.
page/*
page/.*
!page/dist/
!page/dist/**